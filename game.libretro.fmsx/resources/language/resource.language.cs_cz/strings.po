msgctxt "Addon Summary"
msgid "Microsoft - MSX (fMSX)"
msgstr "Microsoft - MSX (fMSX)"

msgctxt "Addon Description"
msgid "fMSX is a MSX emulator written by Marat Fayzullin. It emulates MSX, MSX2, and MSX2+ 8-bit home computers."
msgstr "fMSX je emulátor MSX napsaný Maratem Fayzullinem. Emuluje 8bitové domácí počítače MSX, MSX2 a MSX2+."

msgctxt "Addon Disclaimer"
msgid "Image credit: Garage Research Emulators"
msgstr "Autor obrázku: Garage Research Emulators"

msgctxt "#30001"
msgid "MSX Mode"
msgstr "Režim MSX"

msgctxt "#30002"
msgid "MSX Video Mode"
msgstr "Video režim MSX"

msgctxt "#30003"
msgid "Support high resolution"
msgstr "Podporovat vysoké rozlišení"

msgctxt "#30004"
msgid "Support overscan"
msgstr "Podporovat overscan"

